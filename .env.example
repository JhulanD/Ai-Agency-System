# RESEND_API_KEY: Required for sending welcome emails via Resend.
# Get your key at https://resend.com
# Optional: If not set, email sending will be skipped with a warning
RESEND_API_KEY=

# VITE_LEMON_SQUEEZY_CHECKOUT_URL: The checkout link for your premium plan.
# Get this from your Lemon Squeezy dashboard
# Optional: If not set, the checkout button will not work
VITE_LEMON_SQUEEZY_CHECKOUT_URL=

# VITE_GA_ID: Your Google Analytics Measurement ID (e.g., G-XXXXXXXXXX)
# Optional: If not set, analytics tracking will be disabled
VITE_GA_ID=
