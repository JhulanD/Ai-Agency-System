# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# RESEND_API_KEY: Required for email automation.
# Get your key at https://resend.com
RESEND_API_KEY=

# VITE_LEMON_SQUEEZY_CHECKOUT_URL: The checkout link for your $9 product.
# Get this from your Lemon Squeezy dashboard.
VITE_LEMON_SQUEEZY_CHECKOUT_URL=

# VITE_LEMON_SQUEEZY_UPSELL_URL: The checkout link for your $49 upsell.
# Get this from your Lemon Squeezy dashboard.
VITE_LEMON_SQUEEZY_UPSELL_URL=

# VITE_GA_ID: Your Google Analytics Measurement ID (e.g., G-XXXXXXXXXX)
VITE_GA_ID=
